# Database (Railway PostgreSQL)
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# Auth
SECRET_KEY=your-256-bit-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=coachlenz
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_PROGRAM_MONTHLY=
STRIPE_PRICE_PROGRAM_ANNUAL=
STRIPE_PRICE_ATHLETIC_DEPT_MONTHLY=
STRIPE_PRICE_ATHLETIC_DEPT_ANNUAL=
STRIPE_PRICE_DISTRICT_MONTHLY=
STRIPE_PRICE_DISTRICT_ANNUAL=
STRIPE_PRICE_COACH_TENURE_ATHLETIC=
STRIPE_PRICE_COACH_TENURE_DISTRICT=

# Resend
RESEND_API_KEY=
EMAIL_FROM=CoachLenz <noreply@cosbyaisolutions.com>
ADMIN_EMAIL=info@cosbyaisolutions.com

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
